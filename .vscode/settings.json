{
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.indentSize": "tabSize",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "always",
    "source.organizeImports.biome": "always",
    "source.removeUnusedImports": "always"
  },
  "css.validate": false,
  "[yaml,yml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[html]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true
  },
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true
  },
  "js/ts.experimental.useTsgo": true,
  "js/ts.tsdk.path": "node_modules/@typescript/native-preview-darwin-arm64/lib",
  "tailwindCSS.classAttributes": ["class"],
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(((?:[^()]|\\([^()]*\\))*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["classList={{([^;]*)}}", "\\s*?[\"'`]([^\"'`]*).*?:"],
    ["cn\\(([^]*)\\)", "(?:'|\"|`)([^\"'`]*)(?:'|\"|`)"]
  ],
  "cSpell.language": "en",
  "cSpell.words": [
    "Abatan",
    "adws",
    "bento",
    "Binstall",
    "biomejs",
    "bunx",
    "carere",
    "cmdk",
    "commitlint",
    "Corvu",
    "Cpath",
    "CRDT",
    "Crect",
    "Csvg",
    "Customizer",
    "Embla",
    "esast",
    "extralight",
    "figtree",
    "fontsource",
    "frontmatter",
    "github",
    "grotesk",
    "hovercard",
    "isodate",
    "jsxs",
    "knope",
    "Knope",
    "kobalte",
    "lefthook",
    "linecap",
    "linejoin",
    "lucide",
    "luma",
    "mdxjs",
    "merriweather",
    "networkidle",
    "noto",
    "nowrap",
    "nums",
    "nunito",
    "oklch",
    "oxanium",
    "playfair",
    "raleway",
    "rehype",
    "roboto",
    "shadcn",
    "shiki",
    "shikijs",
    "solidjs",
    "solidstart",
    "Sonner",
    "subcontent",
    "syncer",
    "tablist",
    "tanstack",
    "tsgo",
    "tsrouter",
    "twoslash",
    "UNGH",
    "vaul",
    "velite",
    "vinxi",
    "vite",
    "zaidan"
  ]
}
